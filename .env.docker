# Local Docker Postgres connection (no secrets — safe to commit).
# Used by the `db:*` and `dev:local` npm scripts so local development never
# touches the Supabase credentials in .env. Matches docker-compose.yml.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/testhr?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/testhr?schema=public"
