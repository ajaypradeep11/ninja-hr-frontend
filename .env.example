# ─────────────────────────────────────────────────────────────────────────────
# DEV SWITCH — which backend does the frontend talk to?
#   EMULATOR=true   → LOCAL backend (localhost:4000) + local Postgres
#   EMULATOR=false  → LIVE backend (deployed Cloud Run) + live database
# Firebase Auth is ALWAYS the live project (below) either way — only the
# backend/database target flips.
# ─────────────────────────────────────────────────────────────────────────────
EMULATOR=true

LOCAL_BACKEND_URL="http://localhost:4000/api/v1"
LIVE_BACKEND_URL="https://YOUR-BACKEND.run.app/api/v1"

# Trusted server-to-server key for the local backend (must match its .env).
INTERNAL_API_KEY="dev-internal-key"

# Legacy single-var fallback (used by Firebase App Hosting in production, where
# EMULATOR/LOCAL/LIVE are not set). Leave commented for local dev.
# NINJA_HR_API_URL="http://localhost:4000/api/v1"

# Firebase web app config — LIVE project (Console → Project settings → Web app).
# The web API key is public by design (Next.js inlines NEXT_PUBLIC_* into the
# browser bundle). Fetch a project's values with:
#   firebase apps:sdkconfig WEB --project <projectId>
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID

# Server-side Admin SDK config (token verification) — same live project.
FIREBASE_PROJECT_ID=YOUR_PROJECT_ID

# ── Auth emulator (optional) ─────────────────────────────────────────────────
# To use the Firebase Auth EMULATOR instead of live auth (e.g. offline dev),
# set both hosts below and run `firebase emulators:start --only auth`, then
# `npm run seed:auth` in the backend. Leave unset for live auth.
# NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
