{
  "name": "testhr-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "predev": "npm run db:up && npm run db:migrate && npm run db:ensure-seed",
    "dev": "dotenv -e .env.docker -- next dev",
    "dev:cloud": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:nuke": "docker compose down -v",
    "db:logs": "docker compose logs -f db",
    "db:psql": "docker compose exec -e PGPASSWORD=postgres db psql -U postgres -d testhr",
    "db:migrate": "dotenv -e .env.docker -- prisma migrate deploy",
    "db:ensure-seed": "dotenv -e .env.docker -- tsx prisma/ensure-seed.ts",
    "db:seed:local": "dotenv -e .env.docker -- tsx prisma/seed.ts",
    "db:studio:local": "dotenv -e .env.docker -- prisma studio",
    "db:fresh": "npm run db:nuke && npm run db:up && npm run db:migrate && npm run db:seed:local",
    "db:seed": "dotenv -e .env -- tsx prisma/seed.ts",
    "db:reset": "dotenv -e .env -- prisma migrate reset --force --skip-seed && npm run db:seed",
    "db:studio": "dotenv -e .env -- prisma studio",
    "api:generate": "openapi-typescript http://localhost:4000/api/docs-json -o lib/api/generated/openapi.d.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.456.0",
    "next": "15.1.6",
    "openapi-fetch": "^0.17.0",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "^2.13.3",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.61.1"
  }
}
